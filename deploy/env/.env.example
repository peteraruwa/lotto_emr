# ============================================================
# Lotto Central Hospital EMR — Environment Variables Template
# Copy this file to .env.medplum and .env.web and fill in values.
# NEVER commit real credentials to version control.
# ============================================================

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=medplum
DATABASE_USERNAME=medplum
DATABASE_PASSWORD=change_me_strong_password

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── Medplum Server ───────────────────────────────────────────
MEDPLUM_BASE_URL=http://localhost:8103/
MEDPLUM_ALLOWED_ORIGINS=http://localhost:3000,https://emr.lotto-hospital.local
MEDPLUM_CLIENT_ID=your_medplum_client_id
MEDPLUM_CLIENT_SECRET=your_medplum_client_secret

# ── MinIO (S3-compatible storage) ────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret

# ── Google Gemini AI ─────────────────────────────────────────
# Used by the AI bots for clinical note drafting and summarization.
# Outbound access to generativelanguage.googleapis.com must be allowed
# in the nftables firewall rules.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.lotto-hospital.local
SMTP_PORT=587
SMTP_USERNAME=noreply@lotto-hospital.local
SMTP_PASSWORD=change_me_smtp_password
SMTP_FROM=Lotto Central Hospital EMR <noreply@lotto-hospital.local>

# ── AWS (for cloud deployment only) ──────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=af-south-1

# ── Frontend (Next.js public vars) ───────────────────────────
NEXT_PUBLIC_MEDPLUM_BASE_URL=http://localhost:8103/
NEXT_PUBLIC_MEDPLUM_CLIENT_ID=your_medplum_client_id
